# PowerShare SL — Backend Environment Variables
# මේ file copy කරලා .env කියලා rename කරන්න
# cp .env.example .env

# MongoDB Atlas connection string
# https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/powershare?retryWrites=true&w=majority

# JWT Secret — random strong string දාන්න
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_key_here

# Server port
PORT=3000

# Google OAuth Client ID
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
